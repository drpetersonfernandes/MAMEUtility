<Window
    x:Class="MAMEUtility.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MAMEUtility"
    Title="MAME Utility"
    Height="750" Width="1050" MinHeight="700" MinWidth="800"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource WindowBackgroundBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 0: Header -->
            <RowDefinition Height="*" />    <!-- 1: Main Content -->
            <RowDefinition Height="Auto" /> <!-- 2: StatusBar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="MAME Utility" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeaderTextBrush}" VerticalAlignment="Center" Margin="0,0,30,0" />
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Click="Donate_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AboutButtonBrush}" ToolTip="Donate to support the project">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Donate" Foreground="#121518" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Click="About_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AboutButtonBrush}" ToolTip="View application information">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="About" Foreground="#121518" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Click="Exit_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource ExitButtonBrush}" ToolTip="Close the application">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Exit" Foreground="#121518" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- 0: Tabs Area -->
                <RowDefinition Height="*" />    <!-- 1: LogViewer -->
                <RowDefinition Height="Auto" /> <!-- 2: Progress Area -->
            </Grid.RowDefinitions>

            <!-- Tabs Area -->
            <TabControl Grid.Row="0" x:Name="MainTabControl" Background="Transparent" BorderThickness="0" Margin="0,0,0,15">
                <!-- Tab 1: List Generation & Merge -->
                <TabItem Header="LISTS &amp; UTILS">
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- List Generation -->
                        <GroupBox Header="List Generation" Grid.Column="0" Margin="0,0,10,0" Padding="15">
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button
                                    x:Name="CreateMameFullButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Width="200"
                                    Click="CreateMameFull_Click"
                                    Content="Create MAME Full List"
                                    ToolTip="Generate a consolidated list of all MAME machines from a source XML file" />
                                <Button
                                    x:Name="CreateMameManufacturerButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Width="200"
                                    Click="CreateMameManufacturer_Click"
                                    Content="Create Manufacturer List"
                                    ToolTip="Split the MAME list into separate XML files grouped by manufacturer" />
                                <Button
                                    x:Name="CreateMameYearButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Width="200"
                                    Click="CreateMameYear_Click"
                                    Content="Create Year List"
                                    ToolTip="Split the MAME list into separate XML files grouped by release year" />
                                <Button
                                    x:Name="CreateMameSourcefileButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Width="200"
                                    Click="CreateMameSourcefile_Click"
                                    Content="Create Sourcefile List"
                                    ToolTip="Split the MAME list into separate XML files based on the driver source file" />
                                <Button
                                    x:Name="CreateMameSoftwareListButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Width="200"
                                    Click="CreateMameSoftwareList_Click"
                                    Content="Create Software List"
                                    ToolTip="Process and consolidate multiple software list XML files into a single collection" />
                            </WrapPanel>
                        </GroupBox>

                        <!-- Utilities -->
                        <GroupBox Header="Utilities" Grid.Column="1" Padding="15">
                            <StackPanel Orientation="Vertical" Width="180">
                                <Button
                                    x:Name="MergeListsButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="MergeLists_Click"
                                    Content="Merge Lists"
                                    ToolTip="Combine multiple machine or software XML lists into a single unified file" />
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <!-- Tab 2: Copy ROMs -->
                <TabItem Header="COPY ROMS">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <GroupBox Header="Configuration" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Source ROMs Directory:" />
                                <TextBox Grid.Row="1" Grid.Column="0" x:Name="CopyRomsSourceTextBox" ToolTip="Select the folder containing your source ROM files" />
                                <Button Grid.Row="1" Grid.Column="1" x:Name="BrowseCopyRomsSourceButton" Content="Browse..." Click="BrowseCopyRomsSource_Click" Style="{StaticResource ActionButtonStyle}" />

                                <Label Grid.Row="2" Grid.Column="0" Content="Destination Directory:" Margin="0,10,0,0" />
                                <TextBox Grid.Row="3" Grid.Column="0" x:Name="CopyRomsDestTextBox" ToolTip="Select the folder where ROMs will be copied" />
                                <Button Grid.Row="3" Grid.Column="1" x:Name="BrowseCopyRomsDestButton" Content="Browse..." Click="BrowseCopyRomsDest_Click" Style="{StaticResource ActionButtonStyle}" />

                                <Label Grid.Row="4" Grid.Column="0" Content="Selection XML File(s):" Margin="0,10,0,0" />
                                <TextBox Grid.Row="5" Grid.Column="0" x:Name="CopyRomsXmlTextBox" ToolTip="Select one or more XML files that define which ROMs to copy" />
                                <Button Grid.Row="5" Grid.Column="1" x:Name="BrowseCopyRomsXmlButton" Content="Browse..." Click="BrowseCopyRomsXml_Click" Style="{StaticResource ActionButtonStyle}" />
                            </Grid>
                        </GroupBox>
                        
                        <Button Grid.Row="1" x:Name="StartCopyRomsButton" 
                                Content="Start Copying ROMs" 
                                Click="StartCopyRoms_Click" 
                                Style="{StaticResource StartButtonStyle}" 
                                HorizontalAlignment="Right" Width="250" Height="40" Margin="0,10,0,0"
                                ToolTip="Begin the ROM copying process based on the configured paths" />
                    </Grid>
                </TabItem>

                <!-- Tab 3: Copy Images -->
                <TabItem Header="COPY IMAGES">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <GroupBox Header="Configuration" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Source Images Directory:" />
                                <TextBox Grid.Row="1" Grid.Column="0" x:Name="CopyImagesSourceTextBox" ToolTip="Select the folder containing your source image files (png, jpg)" />
                                <Button Grid.Row="1" Grid.Column="1" x:Name="BrowseCopyImagesSourceButton" Content="Browse..." Click="BrowseCopyImagesSource_Click" Style="{StaticResource ActionButtonStyle}" />

                                <Label Grid.Row="2" Grid.Column="0" Content="Destination Directory:" Margin="0,10,0,0" />
                                <TextBox Grid.Row="3" Grid.Column="0" x:Name="CopyImagesDestTextBox" ToolTip="Select the folder where images will be copied" />
                                <Button Grid.Row="3" Grid.Column="1" x:Name="BrowseCopyImagesDestButton" Content="Browse..." Click="BrowseCopyImagesDest_Click" Style="{StaticResource ActionButtonStyle}" />

                                <Label Grid.Row="4" Grid.Column="0" Content="Selection XML File(s):" Margin="0,10,0,0" />
                                <TextBox Grid.Row="5" Grid.Column="0" x:Name="CopyImagesXmlTextBox" ToolTip="Select one or more XML files that define which images to copy" />
                                <Button Grid.Row="5" Grid.Column="1" x:Name="BrowseCopyImagesXmlButton" Content="Browse..." Click="BrowseCopyImagesXml_Click" Style="{StaticResource ActionButtonStyle}" />
                            </Grid>
                        </GroupBox>

                        <Button Grid.Row="1" x:Name="StartCopyImagesButton" 
                                Content="Start Copying Images" 
                                Click="StartCopyImages_Click" 
                                Style="{StaticResource StartButtonStyle}" 
                                HorizontalAlignment="Right" Width="250" Height="40" Margin="0,10,0,0"
                                ToolTip="Begin the image copying process based on the configured paths" />
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Log Viewer -->
            <Border Grid.Row="1" BorderBrush="{StaticResource TerminalBorderBrush}" BorderThickness="2" CornerRadius="4" Background="{StaticResource TerminalBackgroundBrush}">
                <TextBox x:Name="LogViewer"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         VerticalContentAlignment="Top"
                         IsReadOnly="True"
                         Padding="10"
                         FontFamily="Consolas"
                         FontSize="13"
                         Background="{StaticResource TerminalBackgroundBrush}"
                         Foreground="{StaticResource TerminalForegroundBrush}"
                         BorderThickness="0"
                         TextAlignment="Left"
                         TextWrapping="NoWrap"
                         CaretBrush="{StaticResource TerminalForegroundBrush}"
                         ToolTip="Application activity log and process details">
                    <TextBox.Effect>
                        <DropShadowEffect ShadowDepth="0" Color="#39FF14" BlurRadius="2" Opacity="0.4"/>
                    </TextBox.Effect>
                </TextBox>
            </Border>

            <!-- Progress Area -->
            <Grid x:Name="ProgressAreaGrid" Grid.Row="2" Margin="0,15,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="1" Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="1" Background="{StaticResource CardBackgroundBrush}" ToolTip="Visual progress indicator">
                    <Grid>
                        <ProgressBar x:Name="OverallProgressBar" Height="28" Foreground="{StaticResource ProgressForegroundBrush}" Background="{StaticResource ProgressBackgroundBrush}" BorderThickness="0" />
                        <TextBlock x:Name="ProgressPercentageTextBlock" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="Ready" />
                    </Grid>
                </Border>
                <Button x:Name="CancelProcessingButton" Grid.Row="1" Grid.Column="1" Content="Cancel" Style="{StaticResource CancelButtonStyle}" Margin="10,0,0,0" Click="CancelProcessingButton_Click" Visibility="Collapsed" ToolTip="Abort the current operation" />
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource StatusBarBackgroundBrush}" Padding="5">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusBarText" Text="Ready" Foreground="{StaticResource TextSecondaryBrush}" ToolTip="Current application status" />
            </StatusBarItem>

            <StatusBarItem Grid.Column="1">
                <TextBlock x:Name="StatusBarVersion" Text="{x:Static local:MainWindow.VersionText}" Foreground="{StaticResource TextSecondaryBrush}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>