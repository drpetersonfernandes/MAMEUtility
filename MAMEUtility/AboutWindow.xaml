<Window
    x:Class="MAMEUtility.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="About MAME Utility"
    Width="500"
    Height="570"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource WindowBackgroundBrush}"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Logo Section -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15">
            <StackPanel HorizontalAlignment="Center">
                <Image Width="130" Height="130" Source="pack://application:,,,/images/logo.png" />
            </StackPanel>
        </Border>

        <!-- Title & Version Section -->
        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="20" Foreground="{StaticResource HeaderTextBrush}" Text="MAME Utility" HorizontalAlignment="Center" />
                <TextBlock x:Name="VersionTextBlock" Margin="0,8,0,0" Text="" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryAccentBrush}" FontWeight="SemiBold" FontSize="14" />
            </StackPanel>
        </Border>

        <!-- Description Section -->
        <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Text="Description" Margin="0,0,0,10" />
                <TextBlock TextWrapping="Wrap" Text="A utility for managing MAME ROM lists, merging XML files, and organizing ROM and image collections." Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20" />
                <TextBlock Margin="0,15,0,0">
                    <Hyperlink NavigateUri="https://www.purelogiccode.com" RequestNavigate="Hyperlink_RequestNavigate">
                        https://www.purelogiccode.com
                    </Hyperlink>
                </TextBlock>
                <TextBlock Margin="0,15,0,0">
                    <Hyperlink NavigateUri="https://github.com/drpetersonfernandes/MAMEUtility" RequestNavigate="Hyperlink_RequestNavigate">
                        https://github.com/drpetersonfernandes/MAMEUtility
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Close Button Section -->
        <StackPanel Grid.Row="4" HorizontalAlignment="Center">
            <Button Click="CloseButton_Click" Content="Close" Style="{StaticResource ActionButtonStyle}" Width="100" ToolTip="Close the About window" />
        </StackPanel>
    </Grid>
</Window>